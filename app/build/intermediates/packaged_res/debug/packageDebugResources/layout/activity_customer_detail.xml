<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent" android:layout_height="match_parent"
 android:orientation="vertical" android:background="@color/background">

 <LinearLayout
 android:layout_width="match_parent" android:layout_height="56dp"
 android:background="@drawable/bg_header_gradient" android:gravity="center_vertical"
 android:orientation="horizontal" android:paddingHorizontal="8dp">
 <ImageView android:id="@+id/btnBack"
 android:layout_width="44dp" android:layout_height="44dp" android:padding="10dp"
 android:src="@drawable/ic_back" app:tint="@color/white"/>
 <TextView
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:text="Customer Profile" android:textColor="@color/white"
 android:textSize="19sp" android:textStyle="bold"/>
 </LinearLayout>

 <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:padding="14dp">

 <com.google.android.material.card.MaterialCardView
 android:layout_width="match_parent" android:layout_height="wrap_content"
 app:cardCornerRadius="14dp" app:cardElevation="2dp">
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
 <TextView android:id="@+id/tvAvatar"
 android:layout_width="56dp" android:layout_height="56dp"
 android:background="@drawable/bg_avatar" android:gravity="center"
 android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold"/>
 <LinearLayout
 android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
 android:layout_marginStart="14dp" android:orientation="vertical">
 <TextView android:id="@+id/tvName"
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
 <TextView android:id="@+id/tvInfo"
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:textColor="@color/text_secondary" android:textSize="13sp"/>
 </LinearLayout>
 <ImageView android:id="@+id/btnCall"
 android:layout_width="42dp" android:layout_height="42dp"
 android:background="@drawable/bg_avatar" android:padding="10dp"
 android:src="@drawable/ic_call" app:tint="@color/success"/>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <com.google.android.material.card.MaterialCardView
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:layout_marginTop="12dp" app:cardBackgroundColor="#FBEDED"
 app:cardCornerRadius="14dp" app:cardElevation="0dp">
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
 <TextView android:id="@+id/tvKhata"
 android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
 android:textColor="@color/error" android:textSize="16sp" android:textStyle="bold"/>
 <Button android:id="@+id/btnSettle"
 android:layout_width="wrap_content" android:layout_height="44dp"
 android:backgroundTint="@color/success" android:text="Payment Lein"
 android:textSize="13sp"/>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <TextView style="@style/SectionTitle" android:text=" Job History"
 android:layout_marginTop="16dp"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <LinearLayout
 android:id="@+id/jobsContainer"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical"/>

 <TextView style="@style/SectionTitle" android:text=" Khata History"
 android:layout_marginTop="16dp"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <LinearLayout
 android:id="@+id/khataContainer"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:paddingBottom="24dp"/>
 </LinearLayout>
 </ScrollView>
</LinearLayout>
