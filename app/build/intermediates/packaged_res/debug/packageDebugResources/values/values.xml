<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#F5F5F5</color>
    <color name="divider">#E0E0E0</color>
    <color name="error">#F44336</color>
    <color name="error_light">#FFEBEE</color>
    <color name="primary">#5177B1</color>
    <color name="primary_dark">#175CC1</color>
    <color name="primary_light">#E3F2FD</color>
    <color name="purple">#C161EF</color>
    <color name="status_delivered">#10BAA6</color>
    <color name="status_ready">#4CAF50</color>
    <color name="status_received">#3183E6</color>
    <color name="status_repairing">#E0A552</color>
    <color name="status_rwr">#F44336</color>
    <color name="status_waiting">#9F45CE</color>
    <color name="success">#4CAF50</color>
    <color name="success_light">#E8F5E9</color>
    <color name="teal">#00897B</color>
    <color name="text_primary">#212121</color>
    <color name="text_secondary">#757575</color>
    <color name="warning">#FF9800</color>
    <color name="warning_light">#FFF3E0</color>
    <color name="white">#FFFFFF</color>
    <dimen name="elevation_card">1.5dp</dimen>
    <dimen name="radius_card">14dp</dimen>
    <dimen name="radius_tile">18dp</dimen>
    <dimen name="space_lg">16dp</dimen>
    <dimen name="space_md">12dp</dimen>
    <dimen name="space_sm">8dp</dimen>
    <dimen name="space_xl">24dp</dimen>
    <dimen name="space_xs">4dp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_caption">12sp</dimen>
    <dimen name="text_display">24sp</dimen>
    <dimen name="text_subtitle">16sp</dimen>
    <dimen name="text_title">19sp</dimen>
    <string name="app_name">Mobile JobCard</string>
    <style name="ActionTile">
        <item name="cardCornerRadius">@dimen/radius_tile</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginTop">8dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>
    <style name="SectionTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>
    <style name="StatCard">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="StatLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>
    <style name="StatValue">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    <style name="TextAppearance.App.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.App.Subtitle">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Title">
        <item name="android:textSize">19sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Theme.RevenueAccount" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
    </style>
</resources>