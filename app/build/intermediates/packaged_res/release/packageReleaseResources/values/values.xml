<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#F7F8FA</color>
    <color name="divider">#E7E8EC</color>
    <color name="error">#BB4B4B</color>
    <color name="error_light">#FBEDED</color>
    <color name="primary">#2F6690</color>
    <color name="primary_dark">#204A6B</color>
    <color name="primary_light">#EAF2F8</color>
    <color name="purple">#7A5C93</color>
    <color name="status_delivered">#2F7770</color>
    <color name="status_ready">#357A54</color>
    <color name="status_received">#2F6690</color>
    <color name="status_repairing">#A66418</color>
    <color name="status_rwr">#BB4B4B</color>
    <color name="status_waiting">#7A5C93</color>
    <color name="success">#357A54</color>
    <color name="success_light">#E9F5EE</color>
    <color name="teal">#2F7770</color>
    <color name="text_primary">#26282B</color>
    <color name="text_secondary">#616161</color>
    <color name="warning">#A66418</color>
    <color name="warning_light">#FBF2E6</color>
    <color name="white">#FFFFFF</color>
    <dimen name="elevation_card">1dp</dimen>
    <dimen name="radius_card">16dp</dimen>
    <dimen name="radius_tile">18dp</dimen>
    <dimen name="space_lg">16dp</dimen>
    <dimen name="space_md">12dp</dimen>
    <dimen name="space_sm">8dp</dimen>
    <dimen name="space_xl">24dp</dimen>
    <dimen name="space_xs">4dp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_caption">12sp</dimen>
    <dimen name="text_display">24sp</dimen>
    <dimen name="text_subtitle">16sp</dimen>
    <dimen name="text_title">19sp</dimen>
    <string name="app_name">Mobile JobCard</string>
    <style name="ActionTile">
        <item name="cardCornerRadius">@dimen/radius_tile</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="Input" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginTop">8dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>
    <style name="SectionTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>
    <style name="ShapeAppearance.App.Large" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">20dp</item>
    </style>
    <style name="ShapeAppearance.App.Medium" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.App.Small" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">14dp</item>
    </style>
    <style name="StatCard">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="StatLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>
    <style name="StatValue">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    <style name="TextAppearance.App.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.App.Subtitle">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="TextAppearance.App.Title">
        <item name="android:textSize">19sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Theme.RevenueAccount" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.Large</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>