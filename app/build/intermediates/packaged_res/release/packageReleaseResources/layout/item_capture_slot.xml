<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp" android:layout_height="wrap_content"
    app:cardCornerRadius="12dp" app:cardElevation="0dp"
    app:strokeColor="@color/divider" app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center" android:padding="14dp">
        <FrameLayout
            android:layout_width="32dp" android:layout_height="32dp">
            <ImageView android:id="@+id/ivSlotIcon"
                android:layout_width="match_parent" android:layout_height="match_parent"
                app:tint="@color/primary" android:contentDescription="@null"/>
            <ImageView android:id="@+id/ivSlotCheck"
                android:layout_width="16dp" android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_check_circle" app:tint="@color/success"
                android:visibility="gone" android:contentDescription="@null"/>
        </FrameLayout>
        <TextView android:id="@+id/tvSlotLabel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textSize="12sp" android:gravity="center"
            android:textColor="@color/text_primary"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
