<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@drawable/bg_header_gradient" android:gravity="center_vertical"
        android:orientation="horizontal" android:paddingHorizontal="8dp">
        <ImageView android:id="@+id/btnBack"
            android:layout_width="44dp" android:layout_height="44dp" android:padding="10dp"
            android:src="@drawable/ic_back" app:tint="@color/white"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="New Job Card" android:textColor="@color/white"
            android:textSize="19sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Step indicator: 1 Customer 2 Device 3 Problem 4 Summary -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/white" android:elevation="2dp"
        android:orientation="horizontal" android:padding="12dp"/>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <ViewFlipper
            android:id="@+id/flipper"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- STEP 1: CUSTOMER (auto-fetch). Order: Mobile -> Alternate Mobile -> Name -> Address -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView style="@style/SectionTitle" android:text="Customer Information"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Mobile Number *"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMobile" android:inputType="number" android:digits="0123456789" android:maxLength="10"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <TextView
                    android:id="@+id/tvCustomerFound"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:background="#E9F5EE" android:padding="10dp"
                    android:textColor="#2A6B45" android:textSize="13sp" android:visibility="gone"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Alternate Mobile (Optional)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlternateMobile" android:inputType="number" android:digits="0123456789" android:maxLength="10"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Customer Name *"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName" android:inputType="textPersonName"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Address"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- STEP 2: DEVICE. Single merged Model field, no Color/Storage/Job-title,
                 Screen Lock now has 4 options (None/PIN/Password/Pattern) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView style="@style/SectionTitle" android:text="Device Information"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Device Model * (e.g. Vivo Y20, Redmi Note 10 Pro)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etModel"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input" android:hint="IMEI 1" android:layout_marginTop="0dp"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etImei1" android:inputType="number" android:maxLength="15"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <ImageView android:id="@+id/btnScanImei1"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:layout_marginStart="8dp" android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp" android:src="@drawable/ic_barcode_scan"
                        app:tint="@color/primary" android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input" android:hint="IMEI 2" android:layout_marginTop="0dp"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etImei2" android:inputType="number" android:maxLength="15"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <ImageView android:id="@+id/btnScanImei2"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:layout_marginStart="8dp" android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp" android:src="@drawable/ic_barcode_scan"
                        app:tint="@color/primary" android:contentDescription="@null"/>
                </LinearLayout>

                <!-- Screen Lock: None / PIN / Password / Pattern -->
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="14dp" android:text="Screen Lock"
                    android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <RadioGroup
                    android:id="@+id/rgLockType"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp">
                    <RadioButton android:id="@+id/rbLockNone" android:checked="true"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="None" android:textSize="12sp"/>
                    <RadioButton android:id="@+id/rbLockPin"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="PIN" android:textSize="12sp"/>
                    <RadioButton android:id="@+id/rbLockPassword"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="Password" android:textSize="12sp"/>
                    <RadioButton android:id="@+id/rbLockPattern"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="Pattern" android:textSize="12sp"/>
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPin"
                    style="@style/Input" android:hint="PIN"
                    android:visibility="gone"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword" android:inputType="numberPassword"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPasswordText"
                    style="@style/Input" android:hint="Password"
                    android:visibility="gone"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordText" android:inputType="textPassword"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/patternContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:visibility="gone"
                    android:layout_marginTop="10dp">
                    <com.revenueaccount.app.widgets.PatternLockView
                        android:id="@+id/patternLockView"
                        android:layout_width="220dp" android:layout_height="220dp"/>
                    <TextView android:id="@+id/tvPatternStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="Draw your pattern"
                        android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <Button android:id="@+id/btnClearPattern"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Clear Pattern"/>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Accessories (SIM, cover, memory card...)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAccessories"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- STEP 3: PROBLEM & COST -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView style="@style/SectionTitle" android:text="Problem &amp; Estimate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="What is the problem? *"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etProblem" android:minLines="3" android:gravity="top"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Estimated Cost (Rs.)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCost" android:inputType="numberDecimal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Advance Received (Rs.)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAdvance" android:inputType="numberDecimal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Input" android:hint="Expected Delivery (e.g. Tomorrow evening)"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDelivery"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Customer Documentation: Aadhaar Details / Bill & Box Details -->
                <TextView style="@style/SectionTitle" android:text="Customer Documentation"
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Optional but recommended - keep a documented record for transparency."
                    android:textColor="@color/text_secondary" android:textSize="12sp"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleDocTab"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabAadhaar"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:text="Aadhaar Details" android:textSize="12sp" android:checked="true"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabBill"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="44dp"
                        android:text="Bill / Box Details" android:textSize="12sp"/>
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Tab 1: Aadhaar Details -->
                <LinearLayout android:id="@+id/sectionAadhaar"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="12dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input" android:hint="Aadhaar Number"
                        android:layout_marginTop="0dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAadhaarNumber" android:inputType="number" android:maxLength="12"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="10dp">
                        <include android:id="@+id/slotAadhaarFront" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <include android:id="@+id/slotAadhaarBack" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"/>
                        <include android:id="@+id/slotAadhaarVideo" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Tab 2: Bill / Box Details -->
                <LinearLayout android:id="@+id/sectionBill"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="12dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Input" android:hint="Bill Number"
                        android:layout_marginTop="0dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBillNumber"
                            android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="10dp">
                        <include android:id="@+id/slotBillPhoto" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
                        <include android:id="@+id/slotBoxPhoto" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"/>
                        <include android:id="@+id/slotBillVideo" layout="@layout/item_capture_slot"
                            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- STEP 4: SUMMARY -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView style="@style/SectionTitle" android:text="Summary - Review and Save"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp" app:cardElevation="2dp">
                    <TextView
                        android:id="@+id/tvSummary"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:lineSpacingExtra="6dp" android:padding="16dp"
                        android:textColor="@color/text_primary" android:textSize="14sp"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ViewFlipper>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/white" android:elevation="8dp"
        android:orientation="horizontal" android:padding="12dp">
        <Button
            android:id="@+id/btnPrev"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="52dp"
            android:layout_marginEnd="8dp" android:text="Back" android:visibility="invisible"/>
        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp" android:layout_weight="2" android:layout_height="52dp"
            android:backgroundTint="@color/primary" android:text="Next: Device Information"/>
    </LinearLayout>
</LinearLayout>
