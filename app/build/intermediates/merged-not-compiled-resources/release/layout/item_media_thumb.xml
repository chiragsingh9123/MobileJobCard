<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
 android:layout_width="84dp" android:layout_height="84dp"
 android:layout_marginEnd="8dp">
 <ImageView android:id="@+id/ivThumb"
 android:layout_width="match_parent" android:layout_height="match_parent"
 android:background="@color/divider" android:scaleType="centerCrop"
 android:contentDescription="@null"/>
 <TextView android:id="@+id/tvVideoBadge"
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:layout_gravity="bottom|start" android:layout_margin="4dp"
 android:background="#99000000" android:paddingHorizontal="6dp" android:paddingVertical="2dp"
 android:text="▶ VIDEO" android:textColor="@color/white" android:textSize="9sp"
 android:visibility="gone"/>
 <ImageView android:id="@+id/btnDeleteMedia"
 android:layout_width="24dp" android:layout_height="24dp"
 android:layout_gravity="top|end" android:layout_margin="2dp"
 android:background="@drawable/bg_circle_white" android:padding="4dp"
 android:src="@drawable/ic_close" app:tint="@color/error"
 xmlns:app="http://schemas.android.com/apk/res-auto"/>
</FrameLayout>
