<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="36dp">

    <ImageView android:id="@+id/ivOnboardIcon"
        android:layout_width="180dp" android:layout_height="180dp"
        android:contentDescription="@null"/>

    <TextView android:id="@+id/tvOnboardTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="36dp" android:textColor="@color/text_primary"
        android:textSize="24sp" android:fontFamily="sans-serif-medium"
        android:gravity="center"/>

    <TextView android:id="@+id/tvOnboardDesc"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="14dp" android:textColor="@color/text_secondary"
        android:textSize="15sp" android:gravity="center" android:lineSpacingExtra="4dp"
        android:paddingHorizontal="12dp"/>
</LinearLayout>