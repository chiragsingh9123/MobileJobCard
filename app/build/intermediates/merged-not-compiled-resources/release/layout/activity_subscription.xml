<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent" android:layout_height="match_parent"
 android:orientation="vertical" android:background="@color/background">

 <LinearLayout
 android:layout_width="match_parent" android:layout_height="56dp"
 android:background="@drawable/bg_header_gradient" android:gravity="center_vertical"
 android:orientation="horizontal" android:paddingHorizontal="8dp">
 <ImageView android:id="@+id/btnBack"
 android:layout_width="44dp" android:layout_height="44dp" android:padding="10dp"
 android:src="@drawable/ic_back" app:tint="@color/white"/>
 <TextView
 android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
 android:text="Subscription" android:textColor="@color/white"
 android:textSize="19sp" android:textStyle="bold"/>
 </LinearLayout>

 <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:padding="14dp">

 <TextView android:id="@+id/tvCurrentPlan"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:background="@color/primary_light" android:padding="14dp"
 android:textColor="@color/primary_dark" android:textSize="14sp"
 android:layout_marginBottom="14dp"/>

 <!-- Tab selector -->
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="48dp"
 android:orientation="horizontal" android:background="@color/white"
 android:layout_marginBottom="12dp">
 <Button android:id="@+id/btnTabVoucher"
 style="@style/Widget.Material3.Button.TextButton"
 android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"
 android:text=" Voucher Code"/>
 <Button android:id="@+id/btnTabUpi"
 style="@style/Widget.Material3.Button.TextButton"
 android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"
 android:text=" UPI Payment"/>
 </LinearLayout>

 <!-- ===== VOUCHER SECTION ===== -->
 <LinearLayout android:id="@+id/voucherSection"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical">
 <com.google.android.material.textfield.TextInputLayout
 style="@style/Input"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:hint="Voucher Code (RA-XXXXXXXXXX)">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etVoucherCode" android:inputType="textCapCharacters"
 android:layout_width="match_parent" android:layout_height="wrap_content"/>
 </com.google.android.material.textfield.TextInputLayout>
 <Button android:id="@+id/btnRedeem"
 android:layout_width="match_parent" android:layout_height="52dp"
 android:layout_marginTop="12dp" android:backgroundTint="@color/primary"
 android:text="Redeem Karein"/>
 </LinearLayout>

 <!-- ===== UPI SECTION ===== -->
 <LinearLayout android:id="@+id/upiSection"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:visibility="gone">

 <TextView style="@style/SectionTitle" android:text="1⃣ Plan Chunein"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <LinearLayout android:id="@+id/planContainer"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:layout_marginBottom="14dp"/>

 <TextView style="@style/SectionTitle" android:text="2⃣ QR Scan Karke Pay Karein"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <com.google.android.material.card.MaterialCardView
 android:layout_width="match_parent" android:layout_height="wrap_content"
 app:cardCornerRadius="14dp" app:cardElevation="2dp">
 <LinearLayout
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:gravity="center" android:padding="16dp">
 <ImageView android:id="@+id/ivQr"
 android:layout_width="200dp" android:layout_height="200dp"
 android:background="#F7F8FA" android:scaleType="fitCenter"/>
 <TextView android:id="@+id/tvUpiId"
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:layout_marginTop="10dp" android:textColor="@color/text_primary"
 android:textSize="15sp" android:textStyle="bold"/>
 <TextView android:id="@+id/tvAmount"
 android:layout_width="wrap_content" android:layout_height="wrap_content"
 android:layout_marginTop="4dp" android:textColor="@color/success"
 android:textSize="18sp" android:textStyle="bold"/>
 </LinearLayout>
 </com.google.android.material.card.MaterialCardView>

 <TextView style="@style/SectionTitle" android:text="3⃣ Payment Proof Submit Karein"
 android:layout_marginTop="16dp"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <com.google.android.material.textfield.TextInputLayout
 style="@style/Input"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:hint="UTR / Transaction Number *">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etUtr"
 android:layout_width="match_parent" android:layout_height="wrap_content"/>
 </com.google.android.material.textfield.TextInputLayout>
 <Button android:id="@+id/btnPickScreenshot"
 style="@style/Widget.Material3.Button.OutlinedButton"
 android:layout_width="match_parent" android:layout_height="52dp"
 android:layout_marginTop="10dp" android:text=" Payment Screenshot Chunein"/>
 <ImageView android:id="@+id/ivScreenshotPreview"
 android:layout_width="120dp" android:layout_height="120dp"
 android:layout_marginTop="10dp" android:scaleType="centerCrop"
 android:visibility="gone" android:background="#F7F8FA"/>
 <Button android:id="@+id/btnSubmitPayment"
 android:layout_width="match_parent" android:layout_height="52dp"
 android:layout_marginTop="14dp" android:backgroundTint="@color/success"
 android:text=" Submit Karein"/>
 </LinearLayout>

 <!-- ===== MY PAYMENT REQUESTS HISTORY ===== -->
 <TextView style="@style/SectionTitle" android:text=" Meri Payment Requests"
 android:layout_marginTop="24dp"
 android:layout_width="wrap_content" android:layout_height="wrap_content"/>
 <LinearLayout android:id="@+id/requestsContainer"
 android:layout_width="match_parent" android:layout_height="wrap_content"
 android:orientation="vertical" android:paddingBottom="24dp"/>
 </LinearLayout>
 </ScrollView>
</LinearLayout>
