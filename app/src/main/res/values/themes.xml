<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RevenueAccount" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.Large</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>

    <!-- Consistently soft, rounded corners across buttons, text fields, dialogs and cards -->
    <style name="ShapeAppearance.App.Small" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">14dp</item>
    </style>
    <style name="ShapeAppearance.App.Medium" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.App.Large" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Buttons: soft rounded corners, no harsh sharp edges, gentle letter-spacing -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
