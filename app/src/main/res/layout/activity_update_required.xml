<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="32dp"
    android:background="@color/white">
    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Update Required" android:textSize="22sp"
        android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary"/>
    <TextView android:id="@+id/tvMessage"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:gravity="center" android:textSize="14sp"
        android:textColor="@color/text_secondary"/>
    <Button android:id="@+id/btnUpdate"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginTop="24dp" android:backgroundTint="@color/primary"
        android:text="Update Now"/>
</LinearLayout>